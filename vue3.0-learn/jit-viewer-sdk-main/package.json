{
  "name": "jit-viewer",
  "version": "1.0.1",
  "description": "JitViewer核心SDK - 跨框架文档预览引擎，支持PDF、DOCX、XLSX、PPTX、OFD、TXT、Markdown等格式",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css"
    },
    "./dist/style.css": "./dist/style.css",
    "./iife": {
      "import": "./dist/iife/jit-viewer.min.js",
      "require": "./dist/iife/jit-viewer.min.js"
    },
    "./dist/iife/jit-viewer.min.js": "./dist/iife/jit-viewer.min.js",
    "./dist/iife/jit-viewer.min.css": "./dist/iife/jit-viewer.min.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "build:iife": "vite build --mode iife",
    "build:all": "pnpm build && pnpm build:iife",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.vue",
    "prepublishOnly": "pnpm build:all"
  },
  "keywords": [
    "document-viewer",
    "pdf-viewer",
    "docx-viewer",
    "excel-viewer",
    "ofd-viewer",
    "office-viewer",
    "vue3",
    "react",
    "sdk",
    "jit-viewer"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jitOffice/jit-viewer-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://jitword.com/jit-viewer.html",
  "bugs": {
    "url": "https://github.com/jitOffice/jit-viewer-sdk/issues"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "terser": "^5.46.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  }
}
